}

model Placement {
  id             String          @id @default(cuid())
  filleulId      String
  filleul        User            @relation("PlacementFilleul",      fields: [filleulId],      references: [id])
  requestedById  String
  requestedBy    User            @relation("PlacementRequestedBy",  fields: [requestedById],  references: [id])
  targetParentId String
  targetParent   User            @relation("PlacementTargetParent", fields: [targetParentId], references: [id])
  status         PlacementStatus @default(PENDING)
  expiresAt      DateTime
  placedById     String?
  placedBy       User?           @relation("PlacementPlacedBy",     fields: [placedById],     references: [id])
  placedAt       DateTime?
  method         PlacementMethod?
  createdAt      DateTime        @default(now())
}

model AtlineCommission {
  id                  String           @id @default(cuid())
  userId              String
  user                User             @relation("CommissionReceiver", fields: [userId],       references: [id])
  productId           String
  product             AtlineProduct    @relation(fields: [productId], references: [id])
  sourceUserId        String?
  sourceUser          User?            @relation("CommissionSource",   fields: [sourceUserId], references: [id])
  sourceClientId      String?
  sourceClient        AppClient?       @relation(fields: [sourceClientId], references: [id])
  type                CommissionType
  level               Int
  rate                Float
  amount              Float
  month               DateTime         @db.Date
  // Éligibilité par palier de plan — règle métier : receiver.planTier >= source.planTier
  status              CommissionStatus @default(ELIGIBLE)
  blockedReason       String?          // renseigné si status = BLOCKED (ex: "plan_tier_insuffisant")
  receiverPlanAtTime  Plan             // plan du licencié au moment de la commission
  sourcePlanAtTime    Plan?            // plan de la source (filleul) au moment de la commission
  paidAt              DateTime?
  createdAt           DateTime         @default(now())
}

enum CommissionStatus {
  ELIGIBLE   // commission créée et éligible — sera versée
  PAID       // versée
  BLOCKED    // bloquée — plan du licencié inférieur au plan de la source
  CANCELLED  // annulée (remboursement, résiliation dans la période)
}

model CommissionConfig {
  id             String   @id @default(cuid())
