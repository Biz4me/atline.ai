// ============================================================
// Atline — schema.prisma
// Généré depuis database-schema.md (source de vérité)
// Provider : PostgreSQL (Hetzner VPS 178.105.219.148)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// §1 — UTILISATEUR & PROFIL
// ============================================================

model User {
  id               String         @id @default(cuid())
  username         String         @unique
  email            String         @unique
  emailVerified    DateTime?
  passwordHash     String?
  firstName        String
  lastName         String
  phone            String?
  phone2           String?
  gender           String?
  address          String?
  address2         String?
  postal           String?
  city             String?
  country          String         @default("France")
  photoUrl         String?
  plan             Plan           @default(DISTRIBUTEUR)
  planBillingCycle BillingCycle   @default(MONTHLY)
  planStartedAt    DateTime?
  planExpiresAt    DateTime?
  trialEndsAt      DateTime?
  stripeCustomerId String?        @unique
  kind             UserKind       @default(LICENSEE)
  role             UserRole       @default(USER)
  status           UserStatus     @default(ACTIVE)
  lastLoginAt      DateTime?
  level            Int            @default(1)
  locale           String         @default("fr")
  lat              Float?
  lng              Float?
  bio              String?
  socials          Json?
  coaching         Json?
  birthDate        DateTime?
  hubVisible       Boolean        @default(false)
  onboardingCompleted Boolean     @default(false)
  onboardingStep   Int            @default(0)
  onboardingFlow   OnboardingFlow?
  personality      PersonalityType?
  profession       String?
  education        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Auth
  preferences              UserPreferences?
  accounts                 Account[]
  sessions                 Session[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  // Abonnement & parrainage
  subscription             StripeSubscription?
  userReferralsGiven       UserReferral[]       @relation("UserReferralGiver")
  userReferralsReceived    UserReferral[]       @relation("UserReferralReceiver")
  supportTickets           SupportTicket[]
  ticketMessages           TicketMessage[]

  // MLM & CRM
  mlmBusinesses            UserMlmBusiness[]
  contacts                 Contact[]
  importBatches            ContactImportBatch[]

  // Agenda
  appointments             Appointment[]
  calComConnection         CalComConnection?

  // Atlas
  atlasConversations       AtlasConversation[]
  dailyPlans               DailyPlan[]
  atlasReports             AtlasReport[]

  // LMS
  lmsProgress              UserLmsProgress[]
  lessonProgress           UserLessonProgress[]
  quizAttempts             UserQuizAttempt[]
  certificates             Certificate[]

  // Bibliothèque
  bookInteractions         UserBookInteraction[]

  // ARIA
  simSessions              SimSession[]

  // Nova
  contentPillars           ContentPillar[]
  contentPosts             ContentPost[]
  contentIdeas             ContentIdea[]
  socialAccounts           SocialAccount[]
  socialInboxItems         SocialInboxItem[]

  // Forum
  forumThreads             ForumThread[]
  forumPosts               ForumPost[]
  forumPostLikes           ForumPostLike[]
  forumSaved               ForumSaved[]
  forumReports             ForumReport[]
  contentReports           ContentReport[]

  // Réseau Atline
  atlineReferralsGiven     AtlineReferral[]     @relation("AtlineReferralReferrer")
  atlineReferralsReceived  AtlineReferral[]     @relation("AtlineReferralReferred")
  placements               Placement[]          @relation("PlacementFilleul")
  placementsRequested      Placement[]          @relation("PlacementRequestedBy")
  placementsTargeted       Placement[]          @relation("PlacementTargetParent")
  placementsExecuted       Placement[]          @relation("PlacementPlacedBy")
  commissions              AtlineCommission[]   @relation("CommissionReceiver")
  commissionsSource        AtlineCommission[]   @relation("CommissionSource")
  license                  AtlineLicense?
  licenseeProducts         LicenseeProductCatalog[]
  appClients               AppClient[]

  // Boîte à outils & messagerie
  toolboxLinks             ToolboxLink[]
  toolboxSupports          ToolboxSupport[]
  conversations            Conversation[]
  prospectBots             ProspectBot[]

  // Notifications
  notifications            Notification[]
  pushTokens               PushToken[]

  // Événements
  mlmEventsRequested       MlmEvent[]           @relation("EventRequestedBy")
  mlmEventsValidated       MlmEvent[]           @relation("EventValidatedBy")
  eventRegistrations       EventRegistration[]

  // IA — consommation
  aiUsageLogs              AiUsageLog[]
  telegramLink             TelegramLink?
  aiUsageMonthly           AiUsageMonthly[]
}

model UserPreferences {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotif      Boolean @default(true)
  weeklyDigest    Boolean @default(true)
  mentions        Boolean @default(false)
  theme           String  @default("dark")
  activeCompanyId String?
}

enum Plan {
  DISTRIBUTEUR
  PRO
  LEADER
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  PAUSED
  INACTIVE
}

enum OnboardingFlow {
  STANDARD
  LICENCE_ONLY
  LICENCE_WITH_MLM
}

enum UserKind {
  LICENSEE  // distributeur licencié Atline — accès réseau complet + vente
  CLIENT    // client converti depuis AppClient — accès limité + parrainage simple
}

// ============================================================
// §2 — AUTH (NextAuth)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ============================================================
// §3 — ABONNEMENTS STRIPE
// ============================================================

model StripeSubscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubId        String    @unique
  stripePriceId      String
  status             SubStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model StripeEvent {
  id        String   @id
  type      String
  processed Boolean  @default(false)
  payload   Json
  createdAt DateTime @default(now())
}

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

// ============================================================
// §3b — PARRAINAGE ABONNÉS SIMPLES
// ============================================================

model ReferralConfig {
  id                     String   @id @default(cuid())
  active                 Boolean  @default(true)
  category  String   @default("coaching")
  referrerRewardMonths   Int      @default(1)
  referredDiscountPct    Int      @default(50)
  referredDiscountMonths Int      @default(1)
  updatedAt              DateTime @updatedAt
  updatedById            String?
}

model UserReferral {
  id             String               @id @default(cuid())
  referrerId     String
  referrer       User                 @relation("UserReferralGiver", fields: [referrerId], references: [id])
  referredId     String
  referred       User                 @relation("UserReferralReceiver", fields: [referredId], references: [id])
  rewardSnapshot Json?
  rewardStatus   ReferralRewardStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime             @default(now())

  @@unique([referrerId, referredId])
}

enum ReferralRewardStatus {
  PENDING
  EARNED
  PAID
  CANCELLED
}

// ============================================================
// §3c — SUPPORT
// ============================================================

model SupportTicket {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  subject   String
  priority  TicketPriority @default(NORMAL)
  status    TicketStatus   @default(OPEN)
  messages  TicketMessage[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime      @default(now())
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ============================================================
// §4 — ENTREPRISES MLM DE L'UTILISATEUR
// ============================================================

model UserMlmBusiness {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mlmName       String
  mlmSlug       String
  role          String
  rank          String?
  goal          String?
  objectif      Json?
  produit       String?
  audience      String?
  color         String
  initials      String
  active        Boolean  @default(true)
  category  String   @default("coaching")
  position      Int
  createdAt     DateTime @default(now())

  contacts           Contact[]
  contentPillars     ContentPillar[]
  contentPosts       ContentPost[]
  contentIdeas       ContentIdea[]
  socialAccounts     SocialAccount[]
  socialInboxItems   SocialInboxItem[]
  toolboxLinks       ToolboxLink[]
  toolboxSupports    ToolboxSupport[]
  prospectBots       ProspectBot[]
  conversations      Conversation[]
  appointments       Appointment[]
  dailyPlans         DailyPlan[]
  atlasReports       AtlasReport[]
  atlasConversations AtlasConversation[]
  importBatches      ContactImportBatch[]

  @@unique([userId, mlmSlug])
}

model MlmCatalog {
  id      String  @id @default(cuid())
  name    String  @unique
  slug    String  @unique
  country String  @default("FR")
  active  Boolean @default(true)
  category  String   @default("coaching")
}

// ============================================================
// §5 — CRM — CONTACTS
// ============================================================

model Contact {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  mlmBusinessId String
  mlmBusiness   UserMlmBusiness @relation(fields: [mlmBusinessId], references: [id])
  kind          ContactKind
  name          String
  firstName     String?
  lastName      String?
  gender        String?
  initials      String?
  accent        String?
  email         String?
  phone         String?
  phone2        String?
  address       String?
  address2      String?
  postal        String?
  city          String?
  country       String?
  source        ContactSource?
  isPersonal    Boolean         @default(false)
  convertedUserId String?
  personality   PersonalityType?
  market        MarketTemp?
  profession    String?
  education     String?
  prospectStage ProspectStage?
  clientStage   ClientStage?
  partnerStage  PartnerStage?
  score         Int?
  exposures     Int             @default(0)
  tags          String[]
  lastContact   DateTime?
  note          String?
  lat           Float?
  lng           Float?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  partnerExtra       PartnerExtra?
  clientExtra        ClientExtra?
  atlasConversations AtlasConversation[]
  appointments       Appointment[]
  conversation       Conversation?
  interactions       Interaction[]
}

// Journal des actions CRM (appel/sms/email/…) — fondation des actions, nourrit exposures + lastContact + historique
model Interaction {
  id        String          @id @default(cuid())
  contactId String
  contact   Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  userId    String
  type      InteractionType
  direction String          @default("OUT") // OUT = sortant, IN = entrant
  outcome   String? // POSITIF · NEUTRE · NEGATIF · SANS_REPONSE
  body      String? // texte du message / note
  isExposure Boolean        @default(true) // compte comme une exposition Worre
  createdAt DateTime        @default(now())

  @@index([contactId])
}

model PartnerExtra {
  id          String        @id @default(cuid())
  contactId   String        @unique
  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  team        Int?
  volume      Float?
  onAtline    Boolean       @default(false)
  appReferral Boolean       @default(false)
  scoreAtline Int?
  simSessions Int           @default(0)
  courseDone  Int           @default(0)
  prospects   Int           @default(0)
  lastSeen    DateTime?
  status      PartnerStatus @default(VEILLE)
}

model ClientExtra {
  id          String   @id @default(cuid())
  contactId   String   @unique
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  panier      Float?
  frequency   String?
  lastBuy     DateTime?
  reassortDue Boolean  @default(false)
}

model ContactImportBatch {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  mlmBusinessId String
  mlmBusiness   UserMlmBusiness @relation(fields: [mlmBusinessId], references: [id])
  fileName      String
  totalRows     Int
  imported      Int             @default(0)
  errors        Int             @default(0)
  errorLog      Json?
  status        ImportStatus    @default(PENDING)
  createdAt     DateTime        @default(now())
  completedAt   DateTime?
}

enum ContactKind {
  PROSPECT
  CLIENT
  PARTENAIRE
}

enum ContactSource {
  INSTAGRAM
  LINKEDIN
  FACEBOOK
  TIKTOK
  MANUEL
  BOT_WHATSAPP
  BOT_TELEGRAM
  IMPORT
  RDV_INBOUND
  FAMILLE
  REFERE
  CONNAISSANCE
  CAMPAGNE_EMAIL
  PAGE_CAPTURE
  EVENEMENT
}

enum PersonalityType {
  ROUGE
  VERT
  BLEU
  JAUNE
}

enum MarketTemp {
  CHAUD
  TIEDE
  FROID
}

enum ProspectStage {
  NOUVEAU
  INVITATION
  PRESENTATION
  SUIVI
  CLOSING
}

enum ClientStage {
  C_NOUVEAU
  C_PREMIERE
  C_REGULIER
  C_AMBASSADEUR
}

enum PartnerStage {
  DEMARRAGE
  FORMATION
  ACTIF
  LEADER
}

enum InteractionType {
  APPEL
  SMS
  EMAIL
  WHATSAPP
  DM
  VOCAL
  RDV
  RELANCE
  PARTAGE
  NOTE
  AUTRE
}

enum PartnerStatus {
  MOTEUR
  ENROUTE
  VEILLE
  HORSATLINE
}

enum ImportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// ============================================================
// §6 — AGENDA & RENDEZ-VOUS
// ============================================================

model Appointment {
  id               String              @id @default(cuid())
  userId           String
  user             User                @relation(fields: [userId], references: [id])
  mlmBusinessId    String?
  mlmBusiness      UserMlmBusiness?    @relation(fields: [mlmBusinessId], references: [id])
  contactId        String?
  contact          Contact?            @relation(fields: [contactId], references: [id])
  title            String
  description      String?
  startAt          DateTime
  endAt            DateTime?
  color            String?
  type             AppointmentType     @default(AUTRE)
  done             Boolean             @default(false)
  outcome          AppointmentOutcome?
  outcomeNote      String?
  atlasDebriefId   String?
  atlasDebrief     AtlasConversation?  @relation(fields: [atlasDebriefId], references: [id])
  calComEventId    String?             @unique
  calComBookingUrl String?
  linkedMlmEventId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model CalComConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calComUserId String
  bookingUrl   String
  connected    Boolean  @default(false)
  connectedAt  DateTime?
  updatedAt    DateTime @updatedAt
}

// Connexion calendrier Google (flux OAuth dédié, séparé du login) — Phase 2 agenda
model CalendarConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  provider     String   @default("google")
  email        String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum AppointmentType {
  CALL
  VISIO
  PRESENTIEL
  WEBINAIRE
  FORMATION
  AUTRE
}

enum AppointmentOutcome {
  POSITIF
  NEUTRE
  NEGATIF
  NO_SHOW
}

// ============================================================
// §7 — ATLAS — CHAT, PLAN DU JOUR & RAPPORTS IA
// ============================================================

model AtlasConversation {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  mlmBusinessId String?
  mlmBusiness   UserMlmBusiness? @relation(fields: [mlmBusinessId], references: [id])
  contactId     String?
  contact       Contact?         @relation(fields: [contactId], references: [id])
  title         String?
  context       String?          // "parcours" | "contact" | "reseau" | "messagerie"
  summary       String?          // résumé auto-généré pour l'historique
  messages      AtlasMessage[]
  appointments  Appointment[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model AtlasMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   AtlasConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AtlasRole
  content        String
  qdrantChunks   String[]
  createdAt      DateTime          @default(now())
}

enum AtlasRole {
  USER
  ASSISTANT
}

model DailyPlan {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  mlmBusinessId String
  mlmBusiness   UserMlmBusiness @relation(fields: [mlmBusinessId], references: [id])
  date          DateTime        @db.Date
  generatedAt   DateTime        @default(now())
  tasks         DailyTask[]

  @@unique([userId, mlmBusinessId, date])
}

model DailyTask {
  id                  String    @id @default(cuid())
  planId              String
  plan                DailyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title               String
  subtitle            String?
  icon                String
  color               String
  cta                 String
  position            Int
  done                Boolean   @default(false)
  doneAt              DateTime?
  linkedContactId     String?
  linkedModuleId      String?
  linkedAppointmentId String?
  linkedMlmEventId    String?
  linkedSimPhase      String?
  linkedPostId        String?
  linkedReportId      String?
  linkedBookId        String?
  linkedBotConvId     String?
}

model AtlasReport {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  mlmBusinessId String
  mlmBusiness   UserMlmBusiness @relation(fields: [mlmBusinessId], references: [id])
  type          ReportType
  periodStart   DateTime
  periodEnd     DateTime
  content       String
  highlights    Json?
  read          Boolean         @default(false)
  readAt        DateTime?
  createdAt     DateTime        @default(now())
}

enum ReportType {
  WEEKLY
  MONTHLY
}

// ============================================================
// §8 — FORMATIONS LMS
// ============================================================

model LmsCourse {
  id          String      @id @default(cuid())
  position    Int         @default(0)
  title       String
  description String?
  coverColor  String?
  published   Boolean     @default(false)
  aiGenerated Boolean     @default(false)
  modules     LmsModule[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model LmsModule {
  id          String             @id @default(cuid())
  courseId    String
  course      LmsCourse          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  position    Int                @default(0)
  title       String
  description String?
  published   Boolean            @default(false)
  aiGenerated Boolean            @default(false)
  lessons     LmsLesson[]
  resources   LmsResource[]
  progress    UserLmsProgress[]
  certificates Certificate[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([courseId, position])
}

model LmsLesson {
  id            String               @id @default(cuid())
  moduleId      String
  module        LmsModule            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  position      Int
  kind          LessonKind
  type          LessonType?
  title         String
  content       Json?
  durationMin   Int?
  summary       String?
  passThreshold Int?
  intro         String?
  aiGenerated   Boolean              @default(false)
  published     Boolean              @default(false)
  questions     LmsQuestion[]
  lessonProgress UserLessonProgress[]
  quizAttempts  UserQuizAttempt[]

  @@unique([moduleId, position])
}

model LmsQuestion {
  id             String    @id @default(cuid())
  lessonId       String
  lesson         LmsLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  position       Int
  format         String
  type           QuizType
  question       String
  options        String[]
  correctAnswer  Int?
  correctAnswers Int[]
  correctBool    Boolean?
  correctOrder   Int[]
  lessonRef      String?

  @@unique([lessonId, position])
}

model LmsResource {
  id        String     @id @default(cuid())
  moduleId  String?
  module    LmsModule? @relation(fields: [moduleId], references: [id])
  title     String
  category  ResourceCat
  format    String
  meta      String?
  icon      String
  color     String
  locked    Boolean    @default(false)
  fileUrl   String?
  createdAt DateTime   @default(now())
}

model UserLmsProgress {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  moduleId    String
  module      LmsModule    @relation(fields: [moduleId], references: [id])
  pct         Int          @default(0)
  status      ModuleStatus
  startedAt   DateTime?
  completedAt DateTime?

  @@unique([userId, moduleId])
}

model UserLessonProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      LmsLesson @relation(fields: [lessonId], references: [id])
  done        Boolean   @default(false)
  current     Boolean   @default(false)
  completedAt DateTime?

  @@unique([userId, lessonId])
}

model UserQuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      LmsLesson @relation(fields: [lessonId], references: [id])
  score       Int
  passed      Boolean
  answers     Json
  attemptedAt DateTime  @default(now())
}

model Certificate {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  moduleId String
  module   LmsModule @relation(fields: [moduleId], references: [id])
  earnedAt DateTime  @default(now())

  @@unique([userId, moduleId])
}

enum LessonKind {
  LESSON
  QUIZ
}

enum LessonType {
  VIDEO
  LECTURE
  AUDIO
}

enum QuizType {
  SINGLE
  TRUEFALSE
  MULTI
  ORDER
  SCENARIO
}

enum ResourceCat {
  SCRIPT
  FICHE
  MODELE
  REPLAY
}

enum ModuleStatus {
  LOCKED
  CURRENT
  DONE
}

// ============================================================
// §9 — BIBLIOTHÈQUE — LIVRES MLM
// ============================================================

model MlmBook {
  id               String       @id @default(cuid())
  rang             Int          @unique
