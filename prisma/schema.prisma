}

model RagConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model RagTag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  category  String   @default("coaching")
  createdAt DateTime @default(now())
}

// Bibliothèque audio — plusieurs versions par entité (leçon ou livre)
model AudioAsset {
  id        String   @id @default(cuid())
  kind      String   // "lesson" | "book"
  entityId  String   // lessonId ou slug source_file
  source    String   // "generated" | "uploaded"
  filePath  String   // chemin absolu sur le VPS
  sizeBytes Int?
  model     String?  // modèle LLM utilisé pour la réécriture
  voiceId   String?  // voice ID Cartesia utilisé
  label       String?  // label libre (ex: "Marc v2")
  isActive    Boolean  @default(false) // version jouée par défaut dans l'admin
  isPublished Boolean  @default(false) // visible dans l'app utilisateur
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kind, entityId])
  @@index([kind, isPublished]) // lecture rapide côté app
}

// Relance programmée (« Atlas n'oublie pas ») — déclenchée par n8n à dueAt
model Relance {
  id        String    @id @default(cuid())
  userId    String
  contactId String
  channel   String    @default("email") // whatsapp | sms | email
  dueAt     DateTime
  status    String    @default("PENDING") // PENDING | SENT | CANCELLED
  message   String?
  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([status, dueAt])
}
